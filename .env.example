# Copy to .env and fill in values. Do not commit .env — it is gitignored.

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Paths are relative to the process cwd when running python_rag (use ../data/policies from python_rag/)
POLICIES_PATH=../data/policies
CHROMA_PATH=data/chroma_db
CHROMA_COLLECTION=erp_policies
TOP_K=3

# Hybrid retrieval: BM25 (keyword) + Chroma vector, merged with reciprocal rank fusion (RRF)
HYBRID_RETRIEVAL=true
RRF_K=60
HYBRID_CANDIDATE_MULTIPLIER=2

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Backend — must match the port where uvicorn runs
PORT=5000
NODE_ENV=development
PYTHON_RAG_URL=http://localhost:8001

# Rate limiting on /api routes (requests per window per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_DISABLED=false

# HTTP request logging (morgan). Format: dev, combined, short, tiny, or a custom morgan token string.
HTTP_LOG_FORMAT=dev
HTTP_LOG_DISABLED=false
